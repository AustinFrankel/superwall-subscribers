# Optional private self-host only.
# Leave blank if users will connect from the site UI (recommended for public deploys).

# Required together with ALLOW_ENV_CREDS=1 to enable server-side env credentials.
# Without ALLOW_ENV_CREDS=1 these are ignored (safe for multi-tenant public hosts).
# ALLOW_ENV_CREDS=1
# SUPERWALL_API_KEY=
# SUPERWALL_ORG_ID=
