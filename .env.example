# ─── Optional private self-host only ───────────────────────────
# Leave blank on the public multi-tenant site (users connect in the UI).

# ALLOW_ENV_CREDS=1
# SUPERWALL_API_KEY=
# SUPERWALL_ORG_ID=

# ─── Durable rate limiting (recommended on Vercel) ─────────────
# Create a free Redis DB at https://upstash.com → copy REST credentials.
# Without these, the app falls back to in-memory limits (per instance).

# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
